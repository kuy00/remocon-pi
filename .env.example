# 환경변수 예시 — 복사해서 .env 로 만들고 필요한 값만 덮어쓰면 된다.
#   cp .env.example .env
# 지정하지 않으면 config.py 의 기본값이 쓰인다.

# pigpio 데몬 (원격 라즈베리파이 제어 시 호스트 지정)
PIGPIO_HOST=localhost
PIGPIO_PORT=8888

# GPIO 핀 (BCM)
IR_RX_GPIO=13
IR_TX_GPIO=18

# IR 캐리어 / 타이밍
IR_CARRIER_HZ=38000
IR_GLITCH_US=150
IR_FRAME_GAP_US=30000

# 데이터 경로 / 산출물
IR_DATASET_DIR=dataset
IR_MODEL_FILE=model.json

# 수집 동작 (신뢰도 기준 미달 시 통과할 때까지 재촬영)
IR_REPEATS=8
IR_MIN_AGREE=0.9

# HTTP 서버 (ir_server.py) — LAN에서 봇/앱이 ir_send 호출
IR_HTTP_HOST=0.0.0.0
IR_HTTP_PORT=8000
IR_HTTP_TOKEN=          # 설정 시 'Authorization: Bearer <token>' 요구 (빈값=무인증)
